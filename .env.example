# 複製為 .env 後填入實際值（.env 已列入 .gitignore，不會簽入版控）
TRANSCRIBE_API_URL=http://<主機>:9000/transcribe

# merge-audio-words 使用的 LLM 供應商：gemini、nvidia 或 grok（也可用 --provider 參數覆寫）
LLM_PROVIDER=gemini 
# LLM API 各次請求啟動時間的最小間隔（毫秒；設為 0 可停用，兩種供應商共用）
LLM_REQUEST_INTERVAL_MS=60000
# 每次 LLM request 的純文字提示詞與結果紀錄資料夾
LLM_REQUEST_LOG_DIR=tools/logs/merge-audio-words

# Gemini API Key，請至 https://aistudio.google.com/app/apikey 取得
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>
GEMINI_MODEL=gemini-3.5-flash

# NVIDIA API Key，請至 https://build.nvidia.com 取得（LLM_PROVIDER=nvidia 時必填）
NVIDIA_API_KEY=<YOUR_NVIDIA_API_KEY>
NVIDIA_MODEL=z-ai/glm-5.2
# NVIDIA 的 OpenAI 相容 API base URL（也可用 --base-url 參數覆寫）
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Grok（xAI）API Key，請至 https://console.x.ai 取得（LLM_PROVIDER=grok 時必填）
GROK_API_KEY=<YOUR_GROK_API_KEY>
GROK_MODEL=grok-4.3
# Grok 的 OpenAI 相容 API base URL（也可用 --base-url 參數覆寫）
GROK_BASE_URL=https://api.x.ai/v1
