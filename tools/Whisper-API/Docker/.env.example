# Whisper API 的 Docker Compose 環境設定範例。
# 複製成 .env 後再依部署環境調整；請勿提交實際的 .env。

# Docker image 標籤與主機對外連接埠。
IMAGE_TAG=v1
HOST_PORT=9001

# API 在容器內監聽的連接埠與時區。
PORT=80
TZ=Asia/Taipei

# Hugging Face Token；使用公開模型時通常可以留空。
# 若填入 Token，請確認 .env 未被加入 Git。
HF_TOKEN=

# 在不支援 Windows symbolic link 的環境停用 Hugging Face symlink。
HF_HUB_DISABLE_SYMLINKS=1

# 容器內的暫存檔與 Log 路徑；Compose 會將主機的 ../Temp、../Log 掛載至此。
TEMP_DIR=/app/Temp
LOG_DIR=/app/Log

# 暫存檔保留天數，以及清理程序執行間隔（秒）。
TEMP_RETENTION_DAYS=7
CLEANUP_INTERVAL_SEC=3600

# Log 輪替檔案的保留天數。
LOG_RETENTION_DAYS=30

# 預設 Whisper 模型：tiny、base、small、medium、large 或 turbo。
DEFAULT_MODEL_SIZE=small

# 為維持 API 輸入介面而保留的預設 batch_size。
DEFAULT_BATCH_SIZE=16

# 上傳與 URL 下載的檔案大小上限（MB）。
MAX_UPLOAD_MB=1024
MAX_DOWNLOAD_MB=1024

# URL 下載連線逾時秒數。
DOWNLOAD_TIMEOUT_SEC=120

# NVIDIA Container Toolkit 的 GPU 可見性與驅動能力設定。
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
