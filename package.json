{
  "name": "icrt-news-lunchbox",
  "homepage": "https://lawrence8358.github.io/IcrtNewsLunchbox",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-data-manifest.mjs",
    "start": "ng serve",
    "prebuild": "node scripts/generate-data-manifest.mjs",
    "build": "ng build --base-href=/IcrtNewsLunchbox/",
    "prewatch": "node scripts/generate-data-manifest.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "gh-pages -d dist/browser",
    "cicd": "npm run build && npm run deploy"
  },
  "private": true,
  "overrides": {
    "vite": {
      "esbuild": "^0.28.1"
    }
  },
  "dependencies": {
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-browser-dynamic": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@ng-bootstrap/ng-bootstrap": "^21.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "gh-pages": "^6.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@angular/localize": "^22.0.7",
    "@types/jasmine": "~5.1.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "less": "^4.6.7",
    "typescript": "~6.0.3"
  }
}
