      },
      {
        "start_time": "0:07",
        "end_time": "0:08",
        "text": "小孩的新聞!"
      },
      {
        "start_time": "0:08",
        "end_time": "0:09",
        "text": "真的假的?"
      },
      {
        "start_time": "0:09",
        "end_time": "0:09",
