        "text": "80-90"
      },
      {
        "start_time": "4:23",
        "end_time": "4:24",
        "text": "Q2."
      },
      {
        "start_time": "4:24",
        "end_time": "4:28",
        "text": "How much exercise do children need every day?"
      },
      {
        "start_time": "4:28",
        "end_time": "4:29",
        "text": "A."
      },
      {
        "start_time": "4:29",
        "end_time": "4:30",
        "text": "1 hour"
      },
      {
        "start_time": "4:30",
        "end_time": "4:31",
